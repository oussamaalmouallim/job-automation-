# === n8n Webhooks ===
# Remplace par l'URL de ton instance n8n
VITE_N8N_BASE_URL=https://ton-instance-n8n.app.n8n.cloud

# Scraper LinkedIn (chatTrigger → à remplacer par webhook HTTP après modif)
# Pour l'instant utilise l'URL du chat webhook de n8n
VITE_N8N_SCRAPER_WEBHOOK=http://localhost:5678/webhook/scraper
# Générateur de posts LinkedIn (à créer en Phase 1)
VITE_N8N_POST_WEBHOOK=https://ton-instance-n8n.app.n8n.cloud/webhook/generate-post

# Adaptation lettre de motivation (à créer en Phase 2)
VITE_N8N_LETTER_WEBHOOK=https://ton-instance-n8n.app.n8n.cloud/webhook/adapt-letter

# Recherche offres d'emploi (à créer en Phase 3)
VITE_N8N_JOBS_WEBHOOK=https://ton-instance-n8n.app.n8n.cloud/webhook/search-jobs

# === Supabase (Phase 4) ===
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === App ===
VITE_APP_NAME=LinkedAI
VITE_APP_ENV=development
